@page "/not-found"
@layout MainLayout

<PageTitle>Not found — DrunkDeer</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="1">
        <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
        <MudText Typo="Typo.h6" Class="mt-2">Page not found</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">The content you're looking for doesn't exist.</MudText>
        <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Primary" Href="">Back to Connect</MudButton>
    </MudPaper>
</MudContainer>

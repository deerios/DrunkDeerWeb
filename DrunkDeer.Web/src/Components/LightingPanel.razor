@using MudBlazor.Utilities
@using DrunkDeer.Protocol
@inject KeyboardService Keyboard
@inject KeyboardStore Store
@inject SelectionStore Selection
@inject SettingsService Settings
@inject IDialogService Dialogs
@inject ISnackbar Snackbar
@implements IDisposable

@* The lighting side panel (FUTURE_PLAN §5.4): colours whatever is selected on the on-screen
   keyboard, and drives the board's built-in animations. See KeyboardService.ApplyLightingAsync
   for why the background for unselected keys is asked for up front rather than assumed. *@

<MudPaper Class="pa-4" Elevation="1">
    <MudText Typo="Typo.h6" Class="mb-1">Lighting</MudText>
    <MudText Typo="Typo.caption" Color="Color.Secondary">
        Per-key colours, or one of the board's own animations.
    </MudText>

    <MudDivider Class="my-3" />

    @if (Keyboard.ActiveMode is { } running)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            <b>@Humanize(running)</b> is running. The board generates it itself, so the colours below
            aren't what's on the keyboard right now - applying one switches back to per-key colours.
        </MudAlert>
    }
    else if (Keyboard.BacklightOff)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            The backlight is off. Applying a colour turns it back on.
        </MudAlert>
    }

    @if (Selection.IsEmpty)
    {
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Select keys on the keyboard to colour them.
        </MudText>
    }
    else
    {
        <MudText Typo="Typo.body2" Class="mb-2">
            <b>@Selection.Count</b> @Noun(Selection.Count) selected
        </MudText>

        @* ShowAlpha is off for two reasons: the keyboard has no alpha channel, and it is what turns
           the field's text from #rrggbbaa into a plain #rrggbb worth pasting somewhere else.
           Editable then makes that same field the hex entry, so the colour has one text box rather
           than two showing near-identical strings.

           The swatch is not decoration. The picker silently ignores text it can't parse — it keeps
           the last good colour but leaves the bad text sitting in the field, and it reports none of
           this (TextChanged only fires for values it parsed, so there is nothing to hang an error
           message on). The swatch is then the only thing still showing the colour that would
           actually be written. It is also what opens the picker: it looks like the colour it would
           set, so it is the thing people reach for to change it. *@
        <div class="colour-row mb-2">
            <button type="button" class="swatch" style="background-color:@Hex(_color)"
                    disabled="@_busy" aria-label="@($"Key colour {Hex(_color)}. Opens the colour picker.")"
                    @onclick="@(() => Toggle(_colorPicker))"></button>
            <MudColorPicker @ref="_colorPicker" Value="@_color" ValueChanged="OnColorPicked"
                            Label="Key colour" Placeholder="#000000"
                            Editable="true" ShowAlpha="false"
                            Variant="Variant.Outlined" Margin="Margin.Dense"
                            Disabled="@_busy" Class="flex-grow-1" />
        </div>

        @if (LiveEditActive)
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-2">
                <MudIcon Icon="@Icons.Material.Filled.Bolt" Size="Size.Small" Class="mr-1" />
                Live-editing: colours and brightness land on the keyboard as you set them.
            </MudText>
        }

        @if (!Keyboard.ColorsAreKnown)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mt-3">
                This board can't report its current colours, and the firmware only accepts
                whole-board writes — so applying also colours every key you didn't select.
            </MudAlert>
            @* Same treatment as the key colour above: this is the same control choosing the same
               kind of value, so it gets the same swatch and the same plain #rrggbb. *@
            <div class="colour-row mt-3">
                <button type="button" class="swatch" style="background-color:@Hex(_background)"
                        disabled="@_busy" aria-label="@($"Background colour {Hex(_background)}. Opens the colour picker.")"
                        @onclick="@(() => Toggle(_backgroundPicker))"></button>
                <MudColorPicker @ref="_backgroundPicker" @bind-Value="_background" Label="All other keys"
                                Editable="true" ShowAlpha="false"
                                Variant="Variant.Outlined" Margin="Margin.Dense"
                                Disabled="@_busy" Class="flex-grow-1" />
            </div>
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-3">
                Background brightness: @_backgroundBrightness
            </MudText>
            <MudSlider T="int" @bind-Value="_backgroundBrightness" Min="0" Max="9" Step="1"
                       Immediate="true" Disabled="@_busy" />
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block">
                Dims the background only, so it sits under the keys you picked. The keyboard has one
                brightness for the whole board, so this is applied to the colour itself.
            </MudText>
        }
        else
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                Keys you haven't selected keep the colours this session last wrote.
            </MudText>
        }

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-3">
            Brightness: @_brightness
        </MudText>
        @* Value/ValueChanged rather than a two-way bind, so dragging can write as it goes. Immediate
           still raises a change per pixel; the debounce behind ScheduleLiveWrite is what keeps that
           from being a packet each. *@
        <MudSlider T="int" Value="@_brightness" ValueChanged="OnBrightnessPicked" Min="0" Max="9" Step="1"
                   Immediate="true" Disabled="@_busy" />

        <MudButton Class="mt-2" FullWidth="true" Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Palette" Disabled="@_busy" OnClick="ApplyAsync">
            @(_busy ? "Applying…" : "Apply to keyboard")
        </MudButton>
    }

    <MudDivider Class="my-4" />

    <MudText Typo="Typo.subtitle2" Class="mb-2">Animation</MudText>
    <MudSelect T="LightingMode?" Value="@Keyboard.ActiveMode" ValueChanged="StartModeAsync"
               Label="Effect" Variant="Variant.Outlined" Margin="Margin.Dense"
               Disabled="@_busy" Clearable="false">
        @foreach (var mode in Modes)
        {
            <MudSelectItem T="LightingMode?" Value="@mode">@Humanize(mode!.Value)</MudSelectItem>
        }
    </MudSelect>

    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-3">
        Speed: @_speed
    </MudText>
    <MudSlider T="int" @bind-Value="_speed" Min="0" Max="9" Step="1" Immediate="true" Disabled="@_busy" />

    <MudButton Class="mt-2" FullWidth="true" Variant="Variant.Outlined"
               StartIcon="@Icons.Material.Outlined.Lightbulb"
               Disabled="@(_busy || Keyboard.BacklightOff)" OnClick="TurnOffAsync">
        Turn backlight off
    </MudButton>
</MudPaper>

@code {
    // Every animation the firmware exposes. LightingMode has no "custom" member: per-key colour
    // writes are what select the custom mode, so returning to it means applying a colour.
    private static readonly LightingMode?[] Modes =
        [.. Enum.GetValues<LightingMode>().Select(m => (LightingMode?)m)];

    private MudColor _color = new("#ff5722");
    // A saturated background rather than a near-black one: the brightness below scales it down
    // linearly, so starting dark would land the first write on "everything else went off" — the
    // very impression the explicit background exists to avoid.
    private MudColor _background = new("#3060c0");
    private int _backgroundBrightness = 4;
    private int _brightness = 9;
    private int _speed = 5;
    private bool _busy;

    private MudColorPicker? _colorPicker;
    private MudColorPicker? _backgroundPicker;

    // ── Live editing ─────────────────────────────────────────────────────────

    /// <summary>How long the picker has to sit still before the colour is written.</summary>
    /// <remarks>
    /// Dragging across the picker's palette raises a change per pixel, and each one would otherwise
    /// be a packet. Short enough to feel immediate, long enough that a drag is a handful of writes
    /// rather than hundreds.
    /// </remarks>
    private static readonly TimeSpan LiveEditDelay = TimeSpan.FromMilliseconds(120);

    /// <summary>Holds the writes to one at a time, so two colours can't race onto the board.</summary>
    /// <remarks>
    /// The waiter always sends whatever colour is current when its turn comes, not the one it was
    /// queued with — so being held up can never land a stale colour on the keyboard.
    /// </remarks>
    private readonly SemaphoreSlim _liveWrite = new(1, 1);
    private CancellationTokenSource? _liveDebounce;

    /// <summary>Whether picking a colour writes it to the board straight away.</summary>
    /// <remarks>
    /// <see cref="KeyboardService.ColorsAreKnown"/> is the condition that isn't the setting: the
    /// first colour write of a session sets every key the user *didn't* select (see
    /// <see cref="ApplyAsync"/>), so it asks first. Live-editing that write would be the one thing
    /// the confirmation exists to prevent, arriving before anyone could confirm it. Once the board
    /// has been coloured once, a write only touches the selection, and there is nothing to ask.
    /// </remarks>
    private bool LiveEditActive =>
        Settings.Current.LiveEditColors && Keyboard.ColorsAreKnown && !Selection.IsEmpty;

    /// <summary>Opens the picker a swatch belongs to.</summary>
    /// <remarks>
    /// This is the same call the picker's own adornment button makes, so the swatch behaves exactly
    /// like it — including that a second click does NOT close the popover: the picker's close-on-
    /// outside-click runs first and the toggle then reopens it. Measured on both, and left matching
    /// the built-in control rather than made cleverer. Clicking away is what closes it.
    /// The ref is null only before the first render, and a click can't arrive before then.
    /// </remarks>
    private static Task Toggle(MudColorPicker? picker) => picker?.ToggleOpenAsync() ?? Task.CompletedTask;

    protected override void OnInitialized()
    {
        Selection.Changed += OnSelectionChanged;
        // Board-wide rather than per key, so this one doesn't follow the selection.
        _brightness = Keyboard.LastBrightness;
        SyncColorFromSelection();
    }

    /// <summary>Puts the picker on the colour the selected keys actually hold.</summary>
    /// <remarks>
    /// The picker is a view of the selection, so it follows both the selection changing and the
    /// panel being (re)mounted. Mounting is what catches a profile load: applying one happens on the
    /// Profiles page, and coming back here builds this panel again — as does every tab switch, since
    /// MudTabs disposes the inactive panel (ActuationPanel's preview cleanup relies on the same).
    /// Without this the picker kept showing whatever was last typed while the board showed the
    /// profile's colours.
    /// <para>
    /// Skipped entirely until <see cref="KeyboardService.ColorsAreKnown"/>: the session's colour
    /// profile is not seeded at connect, so before the first write every key reads black, and
    /// syncing to that would drop black into the picker as though someone had chosen it.
    /// </para>
    /// <para>
    /// Reading the shadow back is lossless here. A theme's base colour is scaled by its brightness
    /// on the way in, but per-key colours are stored exactly as written and the brightness rides
    /// the wire beside them — so what comes out is the colour that was picked, not a dimmed one.
    /// </para>
    /// </remarks>
    private void SyncColorFromSelection()
    {
        var session = Keyboard.Session;
        if (session is null || !Keyboard.ColorsAreKnown) return;

        // A mixed selection is represented by its first key in board order. Applying then makes the
        // rest match it, which is exactly what the button underneath says it will do.
        var key = session.Layout.FirstOrDefault(k => Selection.Contains(k.SlotIndex));
        if (key is null) return;

        var (r, g, b) = session.GetKeyColor(key.Key);
        _color = new MudColor(r, g, b, byte.MaxValue);
    }

    /// <summary>Takes the colour the picker moved to, and — when live-editing — starts the clock on writing it.</summary>
    /// <remarks>
    /// Not <c>async</c>: this replaces a two-way binding, and the swatch beside the picker has to
    /// repaint now rather than after the debounce. So the write is left running and the handler
    /// returns, which is what lets Blazor render the new colour immediately.
    /// </remarks>
    private void OnColorPicked(MudColor value)
    {
        _color = value;
        ScheduleLiveWrite();
    }

    /// <summary>Takes the brightness the slider moved to, and — when live-editing — writes it too.</summary>
    /// <remarks>
    /// Board-wide, unlike the colour, so this lands on every key rather than the selection. It still
    /// waits for <see cref="LiveEditActive"/>, which means a session that has never coloured the
    /// board can't dim it from here without going through Apply — the same first-write confirmation
    /// the colour respects, for the same reason: brightness rides the wire beside a whole-board
    /// colour write, so there is no way to send one without the other.
    /// </remarks>
    private void OnBrightnessPicked(int value)
    {
        _brightness = value;
        ScheduleLiveWrite();
    }

    /// <summary>Starts the clock on writing what the panel currently holds.</summary>
    /// <remarks>
    /// Shared by the colour and the brightness: both feed the same whole-board write, so a change to
    /// either restarts the one debounce rather than each running its own. Dragging the brightness
    /// slider right after picking a colour then sends both together, once.
    /// </remarks>
    private void ScheduleLiveWrite()
    {
        if (!LiveEditActive) return;

        var previous = _liveDebounce;
        var cts = new CancellationTokenSource();
        _liveDebounce = cts;
        previous?.Cancel();
        previous?.Dispose();

        _ = WriteSoonAsync(cts);
    }

    private async Task WriteSoonAsync(CancellationTokenSource cts)
    {
        try
        {
            await Task.Delay(LiveEditDelay, cts.Token);
            await _liveWrite.WaitAsync(cts.Token);
        }
        catch (OperationCanceledException)
        {
            // The picker moved again inside the window, or the panel went away. Either way this
            // colour is not the one to write.
            return;
        }
        catch (ObjectDisposedException)
        {
            return; // the panel was disposed while this was queued
        }

        try
        {
            // Re-checked after the wait, not before: the selection can be cleared, or the board
            // unplugged, while this was queued behind another write.
            var keys = SelectedKeys();
            if (keys.Length == 0 || !LiveEditActive) return;

            await Keyboard.ApplyLightingAsync(
                ToRgb(_color), keys, ToRgb(_background),
                (byte)_backgroundBrightness, (byte)_brightness);
        }
        catch (Exception ex)
        {
            // No success message, unlike Apply: this fires while the user is dragging a colour
            // around, and the keyboard lighting up is the confirmation. A failure still gets one —
            // the board silently not following the picker is exactly when an explanation is wanted.
            Snackbar.Add($"Couldn't apply lighting: {ex.Message}", Severity.Error);
        }
        finally
        {
            _liveWrite.Release();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ApplyAsync()
    {
        var keys = SelectedKeys();
        if (keys.Length == 0) return;

        // Only the first write of a session needs confirming: it is the one that colours keys the
        // user never touched. After that the panel leaves them alone.
        if (!Keyboard.ColorsAreKnown && !Settings.Current.SkipWriteConfirmations
            && !await ConfirmFirstWriteAsync(keys.Length))
            return;

        _busy = true;
        try
        {
            await Keyboard.ApplyLightingAsync(
                ToRgb(_color), keys, ToRgb(_background),
                (byte)_backgroundBrightness, (byte)_brightness);
            Snackbar.Add($"Coloured {keys.Length} {Noun(keys.Length)}.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't apply lighting: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task<bool> ConfirmFirstWriteAsync(int selected)
    {
        int others = Math.Max(0, (Keyboard.Session?.Layout.Count ?? 0) - selected);
        var body = Store.IsDemo
            ? $"Colours {selected} selected {Noun(selected)} and sets the other {others} to the background. "
              + "This is a simulated keyboard, so no hardware is touched."
            : $"Colours {selected} selected {Noun(selected)} and sets the other {others} to the background. "
              + "This board's existing colours can't be read back, so any lighting configured elsewhere "
              + "(for example in the official app) will be overwritten.";

        var result = await Dialogs.ShowMessageBoxAsync(
            title: "Light the whole keyboard?",
            markupMessage: new MarkupString(body),
            yesText: "Apply", cancelText: "Cancel");
        return result == true;
    }

    private async Task StartModeAsync(LightingMode? mode)
    {
        if (mode is null) return;
        _busy = true;
        try
        {
            await Keyboard.SetLightingModeAsync(mode.Value, (byte)_brightness, (byte)_speed);
            Snackbar.Add($"{Humanize(mode.Value)} started.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't start the animation: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task TurnOffAsync()
    {
        _busy = true;
        try
        {
            await Keyboard.TurnLightingOffAsync();
            Snackbar.Add("Backlight off.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Couldn't turn the backlight off: {ex.Message}", Severity.Error);
        }
        finally
        {
            _busy = false;
        }
    }

    // The selection is held as firmware slots; the SDK's lighting API speaks DDKey, and the
    // layout is what maps between them.
    private DDKey[] SelectedKeys()
    {
        var session = Keyboard.Session;
        if (session is null) return [];
        return [.. session.Layout.Where(k => Selection.Contains(k.SlotIndex)).Select(k => k.Key)];
    }

    private static RgbColor ToRgb(MudColor c) => new(c.R, c.G, c.B);

    /// <summary>The colour as <c>#rrggbb</c>.</summary>
    /// <remarks>
    /// Deliberately not <c>MudColor.Value</c>, which appends the alpha byte (<c>#3060c0ff</c>).
    /// The keyboard has no alpha channel, and an eight-digit hex is not what anything else takes.
    /// </remarks>
    private static string Hex(MudColor c) => c.ToString(MudColorOutputFormats.Hex);

    /// <summary>Turns an enum name like <c>WaveSpectrum</c> into "Wave spectrum".</summary>
    private static string Humanize(LightingMode mode)
    {
        var name = mode.ToString();
        var sb = new System.Text.StringBuilder(name.Length + 4);
        for (int i = 0; i < name.Length; i++)
        {
            if (i > 0 && char.IsUpper(name[i])) sb.Append(' ').Append(char.ToLowerInvariant(name[i]));
            else sb.Append(name[i]);
        }
        return sb.ToString();
    }

    private static string Noun(int n) => n == 1 ? "key" : "keys";

    private void OnSelectionChanged() => _ = InvokeAsync(() =>
    {
        SyncColorFromSelection();
        StateHasChanged();
    });

    // The panel is disposed on every tab switch, so a debounced write left running would fire at a
    // component that is no longer on screen — and, worse, would still reach the keyboard.
    public void Dispose()
    {
        Selection.Changed -= OnSelectionChanged;
        _liveDebounce?.Cancel();
        _liveDebounce?.Dispose();
        _liveDebounce = null;
        _liveWrite.Dispose();
    }
}

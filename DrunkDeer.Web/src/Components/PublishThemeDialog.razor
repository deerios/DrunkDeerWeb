@using DrunkDeer.Protocol
@inject ProfileLibrary Profiles
@inject ActiveProfile Active
@inject IJSRuntime JS

@* Publishing one of your own profiles to the shared gallery.

   The dialog's job is to fill in a GitHub issue form and hand it to the browser — see
   ThemePublisher for why the app never talks to GitHub itself. Everything a person needs to decide
   is here: which theme, what it is called, and who it is credited to. What happens after they
   submit is the themes repository's business, and the last line says so rather than pretending the
   theme is published the moment this closes. *@

<MudDialog>
    <DialogContent>
        @if (_profiles is null)
        {
            <MudProgressLinear Indeterminate="true" />
        }
        else if (_profiles.Count == 0)
        {
            @* Nothing to publish, and no way to make one from here: themes come from profiles, and
               profiles are saved on the Profiles page. *@
            <MudAlert Severity="Severity.Info" Dense="true">
                You have no saved profiles yet. Set your keyboard's lighting up how you like it, save it as a
                profile on the <MudLink Href="profiles">Profiles</MudLink> page, and it can be published from here.
            </MudAlert>
        }
        else
        {
            <MudSelect T="string" Value="_selected" ValueChanged="Select" Label="Theme to publish"
                       Variant="Variant.Outlined" Margin="Margin.Dense" Class="mb-4">
                @foreach (var profile in _profiles)
                {
                    <MudSelectItem Value="@profile">@profile</MudSelectItem>
                }
            </MudSelect>

            @if (_problem is not null)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">@_problem</MudAlert>
            }
            else if (_theme is not null)
            {
                @* The same static board the gallery draws its cards with, so what you are about to
                   publish is shown by the code that will show it to everyone else. *@
                <div class="publish-thumb mb-4">
                    <KeyboardView Theme="@_theme" />
                </div>

                <MudTextField @bind-Value="_name" Label="Theme name" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Immediate="true" MaxLength="@MaxNameLength"
                              HelperText="What it's called in the gallery. No two themes share a name."
                              Error="@(_name.Length > MaxNameLength)" Class="mb-3" />

                <MudTextField @bind-Value="_author" Label="Credit this theme to" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Immediate="true" MaxLength="@MaxAuthorLength"
                              HelperText="Shown under the theme. Leave empty to be credited as your GitHub username."
                              Placeholder="Your name or handle" />

                @if (!Fits)
                {
                    @* Takes a theme several times bigger than a full keyboard of colours, so this is
                       nearly unreachable — but a URL past GitHub's limit answers with an error page
                       instead of the form, which would lose the theme without saying so. *@
                    <MudAlert Severity="Severity.Info" Dense="true" Class="mt-4">
                        This theme is too big to carry in a link. Publishing will copy it to your clipboard and open
                        an empty form — paste it into the <strong>Theme JSON</strong> box.
                    </MudAlert>
                }
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => Dialog.Cancel())">Close</MudButton>

        @if (CanPublish && Fits)
        {
            @* A real link, not a button that calls window.open: the browser opens it itself, so
               there is no popup to block and no user gesture to spend getting there. *@
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Custom.Brands.GitHub"
                       Href="@Url" Target="_blank" OnClick="Sent">Publish on GitHub</MudButton>
        }
        else
        {
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Custom.Brands.GitHub"
                       Disabled="@(!CanPublish)" OnClick="CopyAndOpenAsync">Publish on GitHub</MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance Dialog { get; set; } = default!;

    // Mirrors the themes repository's own limits (tools/lib/validate.mjs). Kept here so the fields
    // cannot be typed past what the check on the other end would refuse — the check is still the
    // one that decides, and a submission that gets there over-long is turned away with a message.
    private const int MaxNameLength = 40;
    private const int MaxAuthorLength = 40;

    private IReadOnlyList<string>? _profiles;
    private string? _selected;
    private KeyboardTheme? _theme;
    private string? _problem;
    private string _name = "";
    private string _author = "";

    // Every profile's lighting, read once when the dialog opens — see ProfileThemes for why it is
    // up front rather than on selection.
    private ProfileThemes? _lighting;

    private bool CanPublish => _theme is not null && !string.IsNullOrWhiteSpace(_name) && _name.Length <= MaxNameLength;

    // Built on every render rather than cached: it is a string concatenation over two text fields,
    // and a cached copy is one more thing to invalidate as they are typed into.
    private string Url => _theme is null ? "" : ThemePublisher.BuildIssueUrl(_name, _author, _theme);

    private bool Fits => _theme is null || ThemePublisher.Fits(Url);

    protected override async Task OnInitializedAsync()
    {
        _lighting = await ProfileThemes.LoadAsync(Profiles);
        _profiles = _lighting.Names;

        if (_lighting.Pick(Active.Name) is { } chosen) Select(chosen);
    }

    /// <summary>
    /// Shows the chosen profile's lighting.
    /// </summary>
    /// <remarks>
    /// Synchronous, and that is the point: the publish button is a link whose href has to be right
    /// before it is clicked, so the theme is in hand from the moment the dialog opened.
    /// </remarks>
    private void Select(string profile)
    {
        _selected = profile;
        (_theme, _problem) = _lighting?[profile] ?? default;
        // Profile names cannot hold spaces (they are the CLI's file names), but gallery names are
        // free text, so the underscores go back to being the spaces they stood in for.
        if (_theme is not null) _name = profile.Replace('_', ' ');
    }

    // The link does the opening; this only closes the dialog behind it. Nothing is published yet at
    // this point — the user still has to submit the issue on GitHub.
    private void Sent() => Dialog.Close(DialogResult.Ok(_name));

    private async Task CopyAndOpenAsync()
    {
        if (_theme is null) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", ThemePublisher.ToJson(_theme));
        }
        catch (JSException)
        {
            // A browser that refuses the clipboard leaves the user with an empty form and no theme
            // to paste, which is worse than not opening it at all.
            _problem = "This browser wouldn't let the app copy the theme to your clipboard.";
            return;
        }
        await JS.InvokeVoidAsync("open", ThemePublisher.BuildEmptyIssueUrl(), "_blank", "noopener");
        Dialog.Close(DialogResult.Ok(_name));
    }
}
